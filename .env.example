# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database - Cloudflare D1
DATABASE_URL=file:./database/properties.db

# Scraping configuration
SCRAPER_DELAY_SECONDS=2
USER_AGENT=DailyPropertyShow/1.0 (+https://github.com/roamtohome/daily-show)

# GitHub
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=roamtohome/daily-show-system

# Cloudflare (optional - for D1 deployment)
CF_ACCOUNT_ID=your_account_id
CF_API_TOKEN=your_api_token

# Alerting
ALERT_EMAIL=host@example.com
